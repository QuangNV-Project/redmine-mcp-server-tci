# Redmine Configuration (Required)
REDMINE_TCI_URL=https://your-redmine-instance.com
REDMINE_COOKIE=
REDMINE_USERNAME=fallback_user
REDMINE_PASSWORD=fallback_password

# MCP Server Configuration
TRANSPORT=sse
PORT=3000
VALIDATE_SSE_CREDENTIALS=false

# Logging
LOG_LEVEL=info
LOG_THREAD_NAME=main

# CORS and Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MCP_AUTH_TOKEN=your-secret-token-here

# MongoDB (Optional - enables multi-repo project management)
MONGODB_URI_MCP_TCI=mongodb://localhost:27017/redmine-mcp

# Workflow Configuration
WORKFLOW_EXCEL_PATH=./workflow.xlsx
ENFORCE_STRICT_WORKFLOW=false

# Git (Fallback repo path)
GIT_REPO_PATH=

# Branch Format
BRANCH_FORMAT=ticket-id-title

# Session Credential Encryption (Optional - uses default if not set)
CREDENTIAL_ENCRYPTION_KEY=your-32-char-encryption-key-here!
